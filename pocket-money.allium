-- allium: 2
-- Pocket Money Tracker
-- Domain specification for tracking children's pocket money balances

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value ChildName : String {
    -- Trimmed on input; must be non-empty after trimming
    normalise: trim
    requires: length > 0
}

value Pence : Integer {
    -- Positive amount in pence. £5.00 = 500 pence.
    -- Display formatting (pence → "£X.XX") is a view-layer concern only.
    requires: this > 0
}

value Session {
    -- Not a stored entity. Populated from Google OAuth profile data
    -- and held in a signed HTTP-only cookie (see ADR-0016).
    email: String
    name: String
}

value BackupData {
    children: List<ChildSnapshot>
    transactions: List<TransactionSnapshot>
    exported_at: Timestamp

    @guidance
        -- The canonical format contract is a strict Zod schema (ADR-0023).
        -- Both export (serialization) and restore (parsing) go through it.
        -- No .passthrough() — extra fields are rejected on import.
}

value ChildSnapshot {
    name: ChildName
    created_at: Timestamp
}

value TransactionSnapshot {
    child_name: ChildName
    kind: deposit | withdrawal
    amount: Pence
    note: String
    recorded_at: Timestamp
    recorded_by: String                            -- email of the acting parent
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity Child {
    name: ChildName
    created_at: Timestamp

    -- Relationships
    transactions: Transaction with child = this

    -- Derived
    balance: transactions.sum(t => if t.kind = deposit: t.amount else: -t.amount)
}

entity Transaction {
    child: Child
    kind: deposit | withdrawal
    amount: Pence
    note: String
    recorded_at: Timestamp
    recorded_by: String                            -- email of the acting parent (from Session)
}

@guidance TransactionImmutability
    -- Transactions are append-only. There is no edit or delete for individual
    -- transactions. Mistakes are corrected by adding an offsetting transaction
    -- with an explanatory note (e.g. deposit to reverse an erroneous withdrawal).

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    -- All values provided via environment variables (ADR-0018).
    -- See .env.example for the full list with descriptions.

    allowed_emails: Set<String>                 -- env: ALLOWED_EMAILS (comma-separated)
    database_path: String                       -- env: DATABASE_PATH, required, no default
    cookie_secret: String                       -- env: COOKIE_SECRET, signs session cookies (ADR-0016)
    backup_api_key: String                      -- env: BACKUP_API_KEY, authenticates cron job (ADR-0017)
    google_client_id: String                    -- env: GOOGLE_CLIENT_ID
    google_client_secret: String                -- env: GOOGLE_CLIENT_SECRET
    google_redirect_uri: String                 -- env: GOOGLE_REDIRECT_URI, Tailscale hostname (ADR-0009)
    port: Integer = 3000                        -- env: PORT
    default_note: String = "weekly pocket money" -- env: DEFAULT_NOTE
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule RejectUnauthorisedLogin {
    when: GoogleAuthCallback(email)
    requires: email not in config.allowed_emails
    ensures: LoginRejected(email)
}

rule AllowAuthorisedLogin {
    when: GoogleAuthCallback(email, name)
    requires: email in config.allowed_emails
    ensures: SessionCreated(email: email, name: name)
}

rule Logout {
    when: ParentLogsOut(session)
    ensures: SessionDestroyed(session)
}

rule AddChild {
    when: ParentAddsChild(session, name)
    requires: session.email in config.allowed_emails
    requires: not exists Child{name: name}
    ensures: Child.created(name: name, created_at: now)
}

rule RemoveChild {
    when: ParentRemovesChild(session, child)
    requires: session.email in config.allowed_emails
    ensures:
        for t in child.transactions:
            not exists t
    ensures: not exists child
}

rule Deposit {
    when: ParentDeposits(session, child, amount, note)
    requires: session.email in config.allowed_emails
    requires: amount > 0
    ensures: Transaction.created(
        child: child,
        kind: deposit,
        amount: amount,
        note: note,
        recorded_at: now,
        recorded_by: session.email
    )
}

rule Withdraw {
    when: ParentWithdraws(session, child, amount, note)
    requires: session.email in config.allowed_emails
    requires: amount > 0
    ensures: Transaction.created(
        child: child,
        kind: withdrawal,
        amount: amount,
        note: note,
        recorded_at: now,
        recorded_by: session.email
    )
}

rule ExportBackup {
    when: ParentExportsBackup(session)
    requires: session.email in config.allowed_emails
    ensures: BackupProduced(
        children: Children,
        transactions: Transactions,
        exported_at: now
    )
}

rule RestoreBackup {
    when: ParentRestoresBackup(session, backup)
    requires: session.email in config.allowed_emails
    ensures:
        for t in Transactions:
            not exists t
    ensures:
        for c in Children:
            not exists c
    ensures:
        for c in backup.children:
            Child.created(name: c.name, created_at: c.created_at)
    ensures:
        for t in backup.transactions:
            let child = Child{name: t.child_name}
            Transaction.created(
                child: child,
                kind: t.kind,
                amount: t.amount,
                note: t.note,
                recorded_at: t.recorded_at,
                recorded_by: t.recorded_by
            )

    @guidance
        -- Restore is destructive: all existing data is wiped before import.
        -- This is intentional — restore means "replace with this snapshot",
        -- not "merge with current state".
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

invariant PositiveTransactionAmount {
    for t in Transactions:
        t.amount > 0
}

invariant UniqueChildNames {
    for a in Children:
        for b in Children:
            a = b or a.name != b.name
}

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

actor AuthorisedParent {
    identified_by: Session where email in config.allowed_emails

    @guarantee CookieAuth
        -- Every request must carry a valid signed session cookie.
        -- Middleware verifies the signature and checks the email
        -- against config.allowed_emails before any handler runs.
        -- Requests without a valid session redirect to Google login.
}

actor BackupAgent {
    identified_by: config.backup_api_key via Authorization header

    @guarantee ApiKeyAuth
        -- Requests must carry a valid API key in the Authorization header
        -- (e.g. "Bearer <key>"). The key is a static secret shared between
        -- the app and the cron job (see ADR-0017).
        -- This is entirely separate from cookie-based session auth —
        -- backup API routes use their own middleware (ADR-0026).
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface Home {
    facing viewer: AuthorisedParent

    exposes:
        viewer.name
        for child in Children:
            child.name
            child.balance

    provides:
        ParentAddsChild(viewer, name)
        ParentExportsBackup(viewer)              -- browser download: "pocket-money-YYYY-MM-DDTHH-MM-SS.json"
        ParentRestoresBackup(viewer, backup)     -- two-step: upload → confirm (see guidance)
        ParentLogsOut(viewer.session)

    @guidance RestoreConfirmation
        -- Restore is destructive — it wipes all existing data (ADR-0003).
        -- The UI must present a two-step confirmation flow:
        --   1. Parent uploads backup file → app parses and shows a summary
        --      (number of children, number of transactions, export date)
        --   2. Parent explicitly confirms → restore executes
        -- If parsing fails (invalid format, Zod rejection), show an error
        -- and do not proceed to the confirmation step.

    related:
        for child in Children:
            ChildDetail(child)

    @guidance
        -- Balances are displayed as formatted currency (e.g. "£5.00"),
        -- not raw pence. Formatting is a view-layer concern.
}

surface ChildDetail {
    facing viewer: AuthorisedParent

    context child: Child

    exposes:
        child.name
        child.balance
        for t in child.transactions order by recorded_at descending:
            t.kind
            t.amount
            t.note
            t.recorded_at
            t.recorded_by

    provides:
        ParentDeposits(viewer, child, amount, note default config.default_note)
        ParentWithdraws(viewer, child, amount, note default config.default_note)
        ParentRemovesChild(viewer, child)

    @guidance
        -- Transactions are displayed newest-first (reverse chronological).
        -- All transactions are shown — no pagination in v1.
}

surface BackupApi {
    facing agent: BackupAgent

    provides:
        ExportBackup(agent)

    @guidance
        -- Returns BackupData as JSON.
        -- The cron job saves the response to the network share
        -- with a datetime-stamped filename.
        -- Auth is via API key in Authorization header, not session cookie.
        -- Served under a separate route group with API-key middleware (ADR-0026).
}

------------------------------------------------------------
-- Scenarios
------------------------------------------------------------

@guidance ScenarioConventions
    -- Scenarios use concrete values to illustrate behaviour defined by the
    -- rules above. Each scenario is a specific, verifiable example — not a
    -- restatement of the rule in abstract terms.
    --
    -- Amounts are written in pence (the storage unit) with a £ comment for
    -- readability. Balances are always derived (ADR-0005), never set directly.
    --
    -- These scenarios are the contract for Playwright e2e tests. Every happy
    -- path scenario maps to at least one e2e test. Error scenarios map to
    -- tests that verify the correct user-facing feedback.

-- =====================
-- Authentication
-- =====================

scenario AuthorisedParentLogsIn {
    -- A parent with a whitelisted email completes Google OAuth
    -- and lands on the home page, greeted by name.

    given: config.allowed_emails = {"topher@example.com", "sarah@example.com"}
    when: GoogleAuthCallback(email: "topher@example.com", name: "Topher")
    then: SessionCreated(email: "topher@example.com", name: "Topher")
    and: viewer sees Home
    and: Home shows viewer.name = "Topher"
}

scenario UnauthorisedEmailRejected {
    -- Someone with a valid Google account but not in the whitelist
    -- is turned away at the door.

    given: config.allowed_emails = {"topher@example.com", "sarah@example.com"}
    when: GoogleAuthCallback(email: "stranger@example.com")
    then: LoginRejected(email: "stranger@example.com")
    and: viewer does not see Home
}

scenario UnauthenticatedVisitorRedirected {
    -- A request without a valid session cookie is redirected to
    -- the Google OAuth login flow, not shown an error page.

    given: no valid session cookie
    when: visitor requests Home
    then: redirect to Google OAuth
}

scenario ParentLogsOut {
    -- Logging out clears the session cookie and returns the parent
    -- to the login state.

    given: SessionCreated(email: "topher@example.com", name: "Topher")
    when: ParentLogsOut(session)
    then: SessionDestroyed(session)
    and: subsequent requests redirect to Google OAuth
}

-- =====================
-- Home — Viewing Children
-- =====================

scenario HomeShowsAllChildrenWithBalances {
    -- The home page lists every child with their current balance,
    -- derived from the transaction ledger.

    given:
        Child("Alice", balance: 1500)               -- £15.00
        Child("Bob", balance: -200)                  -- -£2.00
    when: viewer sees Home
    then:
        Home shows Child("Alice", balance: "£15.00")
        Home shows Child("Bob", balance: "-£2.00")
}

scenario HomeShowsEmptyStateWhenNoChildren {
    -- A fresh app with no children should make it obvious
    -- that the first step is adding one.

    given: no Children exist
    when: viewer sees Home
    then: Home shows no children
    and: ParentAddsChild action is available
}

-- =====================
-- Home — Adding a Child
-- =====================

scenario AddChildWithEmptyBalance {
    -- A new child starts with zero balance (no transactions).

    given: no Children exist
    when: ParentAddsChild(session, name: "Alice")
    then: Child("Alice") exists
    and: Child("Alice").balance = 0
    and: Child("Alice").transactions is empty
    and: Home shows Child("Alice", balance: "£0.00")
}

scenario AddChildRejectsDuplicateName {
    -- Child names are unique (ADR-0015). Attempting to add a
    -- duplicate shows an error without creating a second child.

    given: Child("Alice") exists
    when: ParentAddsChild(session, name: "Alice")
    then: error shown: name already exists
    and: Children count unchanged
}

scenario AddChildRejectsEmptyName {
    -- The ChildName value type requires non-empty after trimming.

    when: ParentAddsChild(session, name: "   ")
    then: error shown: name is required
    and: no Child created
}

scenario AddChildTrimsWhitespace {
    -- Leading/trailing whitespace is normalised away, not rejected.

    when: ParentAddsChild(session, name: "  Alice  ")
    then: Child("Alice") exists
    and: Home shows Child("Alice")
}

-- =====================
-- Child Detail — Viewing
-- =====================

scenario ViewChildDetailShowsBalanceAndHistory {
    -- The detail page shows the child's name, current balance,
    -- and full transaction history newest-first.

    given:
        Child("Alice")
        Transaction(child: "Alice", kind: deposit,    amount: 500, note: "weekly pocket money", recorded_at: t1, recorded_by: "topher@example.com")
        Transaction(child: "Alice", kind: deposit,    amount: 500, note: "weekly pocket money", recorded_at: t2, recorded_by: "sarah@example.com")
        Transaction(child: "Alice", kind: withdrawal, amount: 300, note: "comic book",          recorded_at: t3, recorded_by: "topher@example.com")
    when: viewer sees ChildDetail("Alice")
    then:
        ChildDetail shows child.name = "Alice"
        ChildDetail shows child.balance = "£7.00"      -- (500 + 500 - 300) = 700 pence
        transactions shown in order: [t3, t2, t1]       -- newest first
        each transaction shows kind, amount, note, recorded_at, recorded_by
}

scenario ViewChildDetailWithNoTransactions {
    -- A newly added child has no history yet.

    given: Child("Alice") with no transactions
    when: viewer sees ChildDetail("Alice")
    then:
        ChildDetail shows child.balance = "£0.00"
        ChildDetail shows no transactions
}

-- =====================
-- Child Detail — Deposits
-- =====================

scenario DepositIncreasesBalance {
    -- A deposit adds to the child's balance and appears at the
    -- top of the transaction history.

    given: Child("Alice", balance: 500)                  -- £5.00
    when: ParentDeposits(session: "topher@example.com", child: "Alice", amount: 250, note: "weekly pocket money")
    then:
        Child("Alice").balance = 750                     -- £7.50
        new Transaction visible at top of ChildDetail("Alice"):
            kind: deposit
            amount: "£2.50"
            note: "weekly pocket money"
            recorded_by: "topher@example.com"
}

scenario DepositUsesDefaultNote {
    -- When the parent doesn't change the pre-filled note,
    -- the default is used.

    when: ParentDeposits(session, child: "Alice", amount: 500, note: config.default_note)
    then: new Transaction has note = "weekly pocket money"
}

scenario DepositWithCustomNote {
    -- The parent can replace the default note with something specific.

    when: ParentDeposits(session, child: "Alice", amount: 1000, note: "birthday money from gran")
    then: new Transaction has note = "birthday money from gran"
}

scenario DepositRejectsZeroAmount {
    -- The Pence value type requires amount > 0.

    when: ParentDeposits(session, child: "Alice", amount: 0, note: "weekly pocket money")
    then: error shown: amount must be greater than zero
    and: no Transaction created
}

scenario DepositRejectsNegativeAmount {
    -- Negative amounts are not valid. Withdrawals are a separate action.

    when: ParentDeposits(session, child: "Alice", amount: -500, note: "weekly pocket money")
    then: error shown: amount must be greater than zero
    and: no Transaction created
}

-- =====================
-- Child Detail — Withdrawals
-- =====================

scenario WithdrawalDecreasesBalance {
    given: Child("Alice", balance: 500)                  -- £5.00
    when: ParentWithdraws(session: "topher@example.com", child: "Alice", amount: 200, note: "sweets")
    then:
        Child("Alice").balance = 300                     -- £3.00
        new Transaction visible at top of ChildDetail("Alice"):
            kind: withdrawal
            amount: "£2.00"
            note: "sweets"
            recorded_by: "topher@example.com"
}

scenario WithdrawalCanGoNegative {
    -- No floor on balance (ADR-0004). Parents can "sub" their kids.

    given: Child("Alice", balance: 200)                  -- £2.00
    when: ParentWithdraws(session, child: "Alice", amount: 500, note: "advance on next week")
    then:
        Child("Alice").balance = -300                    -- -£3.00
        ChildDetail("Alice") shows balance as "-£3.00"
}

scenario WithdrawalFromZeroBalance {
    -- Even a zero balance doesn't block a withdrawal.

    given: Child("Bob", balance: 0)
    when: ParentWithdraws(session, child: "Bob", amount: 100, note: "ice cream")
    then: Child("Bob").balance = -100                    -- -£1.00
}

-- =====================
-- Child Detail — Correcting Mistakes
-- =====================

scenario CorrectMistakeWithOffsettingTransaction {
    -- Transactions are immutable (ADR-0020). A wrong withdrawal
    -- is fixed by depositing the same amount back with a note.

    given:
        Child("Alice", balance: 300)                     -- £3.00
        -- Oops: parent recorded £5.00 withdrawal but it should have been £2.00
        Transaction(child: "Alice", kind: withdrawal, amount: 500, note: "shoes")
        -- Alice's balance is now -£2.00
    when: ParentDeposits(session, child: "Alice", amount: 500, note: "correction: shoes was £2 not £5")
    and: ParentWithdraws(session, child: "Alice", amount: 200, note: "shoes (corrected)")
    then:
        Child("Alice").balance = 100                     -- £1.00 (300 - 500 + 500 - 200)
        -- All three transactions visible in history — the mistake,
        -- the reversal, and the correct entry
}

-- =====================
-- Child Detail — Removing a Child
-- =====================

scenario RemoveChildDeletesEverything {
    -- Hard delete (ADR-0006). Child and all transactions are gone.

    given:
        Child("Bob")
        Transaction(child: "Bob", kind: deposit, amount: 500, note: "weekly pocket money")
    when: ParentRemovesChild(session, child: "Bob")
    then:
        not exists Child("Bob")
        Home does not show "Bob"
        no transactions for "Bob" exist in database
}

scenario RemoveChildWithNoTransactions {
    -- Removing a freshly added child (e.g. to fix a typo in the name).

    given: Child("Boob") with no transactions              -- typo!
    when: ParentRemovesChild(session, child: "Boob")
    then: not exists Child("Boob")
    and: ParentAddsChild(session, name: "Bob")             -- re-add with correct name
    and: Child("Bob") exists with balance = 0
}

-- =====================
-- Backup — Export
-- =====================

scenario ExportBackupViaBrowser {
    -- Parent downloads a JSON backup file from the home page.
    -- The file contains all children and transactions.

    given:
        Child("Alice", created_at: t1)
        Child("Bob", created_at: t2)
        Transaction(child: "Alice", kind: deposit, amount: 500, note: "weekly pocket money", recorded_at: t3, recorded_by: "topher@example.com")
    when: ParentExportsBackup(session)
    then: browser downloads file named "pocket-money-YYYY-MM-DDTHH-MM-SS.json"
    and: file contains BackupData:
        children: [
            {name: "Alice", created_at: t1},
            {name: "Bob", created_at: t2}
        ]
        transactions: [
            {child_name: "Alice", kind: deposit, amount: 500, note: "weekly pocket money", recorded_at: t3, recorded_by: "topher@example.com"}
        ]
        exported_at: now
}

scenario ExportBackupViaApiKey {
    -- The cron job (ADR-0008) calls the backup API with an API key.

    given: config.backup_api_key = "secret-key-123"
    when: GET /api/backup with Authorization: "Bearer secret-key-123"
    then: 200 OK with BackupData as JSON body
}

scenario ExportBackupApiRejectsInvalidKey {
    when: GET /api/backup with Authorization: "Bearer wrong-key"
    then: 401 Unauthorized
}

scenario ExportBackupApiRejectsMissingKey {
    when: GET /api/backup with no Authorization header
    then: 401 Unauthorized
}

-- =====================
-- Backup — Restore
-- =====================

scenario RestoreShowsConfirmationBeforeExecuting {
    -- Restore is a two-step flow (destructive operation).
    -- Step 1: upload and parse. Step 2: confirm.

    given:
        Child("Alice", balance: 500)                     -- existing data
        valid backup file containing Child("Bob") and 3 transactions
    when: parent uploads backup file on Home
    then:
        app shows restore summary:
            children: 1 (Bob)
            transactions: 3
            exported_at: <date from backup>
        existing data is NOT yet deleted
    when: parent confirms restore
    then:
        not exists Child("Alice")                        -- old data wiped
        Child("Bob") exists                              -- backup data restored
        3 transactions for "Bob" exist
}

scenario RestoreRejectsInvalidFile {
    -- A file that fails Zod parsing (ADR-0023) is rejected
    -- at the upload step — no confirmation, no data loss.

    given: Child("Alice", balance: 500)
    when: parent uploads file with invalid JSON structure
    then:
        error shown: invalid backup file
        Child("Alice") still exists with balance unchanged
        no confirmation step shown
}

scenario RestoreRejectsExtraFields {
    -- Strict Zod parsing rejects unknown fields (no .passthrough()).

    when: parent uploads backup with extra fields (e.g. "colour": "blue" on a child)
    then: error shown: invalid backup file
}

scenario RestoreFromEmptyBackup {
    -- A valid backup with zero children and zero transactions
    -- wipes existing data and leaves the app empty.

    given: Child("Alice", balance: 500)
    and: valid backup file with children: [], transactions: [], exported_at: t1
    when: parent uploads and confirms restore
    then:
        no Children exist
        no Transactions exist
        Home shows empty state
}

-- =====================
-- Audit Trail
-- =====================

scenario TransactionRecordsWhichParentActed {
    -- Each parent's actions are distinguishable in the ledger.

    given: Child("Alice")
    when: ParentDeposits(session: {email: "topher@example.com"}, child: "Alice", amount: 500, note: "weekly pocket money")
    and: ParentDeposits(session: {email: "sarah@example.com"}, child: "Alice", amount: 500, note: "weekly pocket money")
    then:
        ChildDetail("Alice") shows two transactions:
            transaction 1 (newest): recorded_by = "sarah@example.com"
            transaction 2 (oldest): recorded_by = "topher@example.com"
}

-- =====================
-- Multi-Child Isolation
-- =====================

scenario TransactionsAreIsolatedPerChild {
    -- Depositing to one child doesn't affect another's balance.

    given:
        Child("Alice", balance: 500)
        Child("Bob", balance: 300)
    when: ParentDeposits(session, child: "Alice", amount: 200, note: "bonus")
    then:
        Child("Alice").balance = 700
        Child("Bob").balance = 300                       -- unchanged
}

-- =====================
-- Currency Display
-- =====================

scenario AmountsDisplayedAsPoundsAndPence {
    -- All user-facing amounts are formatted as £X.XX (ADR-0014).
    -- Pence is the storage unit; display formatting is a view concern.

    given:
        Child("Alice")
        Transaction(child: "Alice", kind: deposit, amount: 50, note: "found in sofa")     -- £0.50
        Transaction(child: "Alice", kind: deposit, amount: 1000, note: "birthday")         -- £10.00
        Transaction(child: "Alice", kind: deposit, amount: 1525, note: "chores")           -- £15.25
    when: viewer sees ChildDetail("Alice")
    then:
        ChildDetail shows balance = "£25.75"
        transactions show amounts: "£15.25", "£10.00", "£0.50"
}
