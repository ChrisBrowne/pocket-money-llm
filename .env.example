# Pocket Money Tracker — Environment Variables
# Copy to .env and fill in values. See ADR-0018 for the env var convention.

# --- Required ---

# SQLite database file path (ADR-0022)
# Dev: ./data/pocket-money.db | Prod: /var/lib/pocket-money/pocket-money.db
DATABASE_PATH=

# Google OAuth credentials (ADR-0002)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth callback URL — must use Tailscale MagicDNS hostname (ADR-0009)
# e.g. https://pocketmoney.tail1234.ts.net/auth/callback
GOOGLE_REDIRECT_URI=

# Comma-separated email addresses allowed to use the app (ADR-0002)
ALLOWED_EMAILS=

# Secret key for signing session cookies (ADR-0016)
# Generate with: openssl rand -base64 32
COOKIE_SECRET=

# Static API key for the backup cron job (ADR-0017)
# Generate with: openssl rand -base64 32
BACKUP_API_KEY=

# --- Optional (have defaults) ---

# Server port (default: 3000)
# PORT=3000

# Default note pre-filled on transaction forms (default: "weekly pocket money")
# DEFAULT_NOTE=weekly pocket money
